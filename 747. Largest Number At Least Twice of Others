class Solution {
public:
    int dominantIndex(vector<int>& nums) {
        int max = nums[0];
        int idx = 0;
        for(int i=0; i<nums.size();i++){
            if(nums[i] > max) {
                max = nums[i];
                idx = i;
            }
        }
        int flag = 1;
        for(int i=0;i<nums.size();i++){
            if(nums[i] != max && nums[i]*2 > max) {
                flag = 0;
            }
        }
        if(flag == 0){
            return -1;
        }
        return idx;
    }
};
